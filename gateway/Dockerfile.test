# Dockerfile for running gateway tests
FROM eclipse-temurin:21-jdk-alpine AS builder
WORKDIR /build

# Copy project files
COPY build.gradle settings.gradle gradlew ./
COPY gradle/ gradle/
RUN chmod +x gradlew

COPY gateway/ gateway/
COPY common/ common/

# Run tests
RUN ./gradlew :gateway:test --no-daemon || true

# Copy test results
FROM alpine:latest
COPY --from=builder /build/gateway/build/reports/tests/ /test-reports/
COPY --from=builder /build/gateway/build/test-results/ /test-results/
CMD ["cat", "/test-results/test/TEST-com.agentbanking.gateway.filter.JwtAuthGatewayFilterFactoryTest.xml"]
