FROM eclipse-temurin:21-jdk-alpine
WORKDIR /build

# Copy project files
COPY build.gradle settings.gradle gradlew ./
COPY gradle/ gradle/
RUN chmod +x gradlew

COPY gateway/ gateway/
COPY common/ common/

# Install curl for debugging
RUN apk add --no-cache curl

# Run E2E tests - use host network to access services
# Note: This requires running with --network=host
ENTRYPOINT ["./gradlew", ":gateway:e2eTest", "--no-daemon", "--continue"]
