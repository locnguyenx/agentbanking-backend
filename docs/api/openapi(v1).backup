openapi: 3.0.3
info:
  title: Agent Banking Platform - External API
  description: |
    REST API for POS terminals (Android/Flutter channel apps) connecting to the Agent Banking Platform.
    All requests must include Bearer JWT token and X-Idempotency-Key header.
  version: 1.0.0
  contact:
    name: Agent Banking Platform Team

servers:
  - url: https://api.agentbanking.example.com
    description: Production
  - url: https://sandbox.agentbanking.example.com
    description: Sandbox
  - url: http://localhost:8080
    description: Local development (via Gateway)

security:
  - bearerAuth: []

tags:
  - name: Withdrawal
    description: Cash withdrawal transactions
  - name: Deposit
    description: Cash deposit transactions
  - name: Balance
    description: Balance inquiry
  - name: KYC
    description: e-KYC and Onboarding
  - name: Backoffice
    description: Bank operator endpoints

paths:
  /api/v1/withdrawal:
    post:
      tags: [Withdrawal]
      summary: Cash withdrawal (EMV + PIN)
      description: |
        Process a cash withdrawal at an agent location.
        Customer presents EMV card with PIN. Agent collects cash from float.
        Requires geofence validation (within 100m of registered merchant GPS).
      operationId: processWithdrawal
      parameters:
        - $ref: '#/components/parameters/XIdempotencyKey'
        - $ref: '#/components/parameters/XPosTerminalId'
        - $ref: '#/components/parameters/XGpsLatitude'
        - $ref: '#/components/parameters/XGpsLongitude'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WithdrawalRequest'
            example:
              amount: 500.00
              card_data: "encrypted_card_blob_from_pos"
              pin_block: "dukpt_encrypted_pin_block"
              currency: "MYR"
      responses:
        '200':
          description: Withdrawal completed successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionSuccessResponse'
              example:
                status: "COMPLETED"
                transaction_id: "TXN-a1b2c3d4-e5f6"
                amount: 500.00
                customer_fee: 1.00
                reference_number: "PAYNET-REF-789"
                timestamp: "2026-03-25T14:30:00+08:00"
        '400':
          $ref: '#/components/responses/ValidationError'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '422':
          description: Business logic failure
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              examples:
                insufficientFloat:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_INSUFFICIENT_FLOAT"
                      message: "Agent float balance insufficient"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-123"
                      timestamp: "2026-03-25T14:30:00+08:00"
                limitExceeded:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_LIMIT_EXCEEDED"
                      message: "Daily withdrawal limit exceeded"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-124"
                      timestamp: "2026-03-25T14:30:00+08:00"
                geofenceViolation:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_GEOFENCE_VIOLATION"
                      message: "Transaction outside 100m geofence"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-125"
                      timestamp: "2026-03-25T14:30:00+08:00"
                velocityExceeded:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_VELOCITY_COUNT_EXCEEDED"
                      message: "Daily transaction count exceeded for this MyKad"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-126"
                      timestamp: "2026-03-25T14:30:00+08:00"
        '503':
          $ref: '#/components/responses/ServiceUnavailable'

  /api/v1/deposit:
    post:
      tags: [Deposit]
      summary: Cash deposit
      description: |
        Process a cash deposit at an agent location.
        Validates destination account via ProxyEnquiry before crediting.
        Agent receives cash from customer, float is credited.
      operationId: processDeposit
      parameters:
        - $ref: '#/components/parameters/XIdempotencyKey'
        - $ref: '#/components/parameters/XPosTerminalId'
        - $ref: '#/components/parameters/XGpsLatitude'
        - $ref: '#/components/parameters/XGpsLongitude'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DepositRequest'
            example:
              amount: 1000.00
              destination_account: "1234567890"
              currency: "MYR"
      responses:
        '200':
          description: Deposit completed successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionSuccessResponse'
        '400':
          $ref: '#/components/responses/ValidationError'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '422':
          description: Business logic failure
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              examples:
                invalidAccount:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_INVALID_ACCOUNT"
                      message: "Destination account not found"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-200"
                      timestamp: "2026-03-25T14:35:00+08:00"
        '503':
          $ref: '#/components/responses/ServiceUnavailable'

  /api/v1/balance-inquiry:
    post:
      tags: [Balance]
      summary: Customer balance inquiry
      description: |
        Check customer account balance via card + PIN authentication.
        Card number is masked in all responses and logs.
      operationId: customerBalanceInquiry
      parameters:
        - $ref: '#/components/parameters/XIdempotencyKey'
        - $ref: '#/components/parameters/XPosTerminalId'
        - $ref: '#/components/parameters/XGpsLatitude'
        - $ref: '#/components/parameters/XGpsLongitude'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BalanceInquiryRequest'
            example:
              card_data: "encrypted_card_blob"
              pin_block: "dukpt_encrypted_pin_block"
      responses:
        '200':
          description: Balance inquiry successful
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BalanceInquiryResponse'
              example:
                status: "COMPLETED"
                balance: 15000.00
                currency: "MYR"
                account_masked: "****7890"
                timestamp: "2026-03-25T14:40:00+08:00"
        '401':
          $ref: '#/components/responses/Unauthorized'
        '422':
          description: Balance inquiry failed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'

  /api/v1/agent/balance:
    get:
      tags: [Balance]
      summary: Agent wallet balance
      description: |
        Check agent's virtual wallet balance.
        Agent identity is extracted from JWT token.
      operationId: agentBalanceInquiry
      parameters:
        - $ref: '#/components/parameters/XIdempotencyKey'
        - $ref: '#/components/parameters/XPosTerminalId'
      responses:
        '200':
          description: Agent balance retrieved
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AgentBalanceResponse'
              example:
                status: "COMPLETED"
                balance: 10000.00
                reserved_balance: 500.00
                available_balance: 9500.00
                currency: "MYR"
                timestamp: "2026-03-25T14:40:00+08:00"
        '401':
          $ref: '#/components/responses/Unauthorized'

  /api/v1/kyc/verify:
    post:
      tags: [KYC]
      summary: MyKad verification via JPN
      description: |
        Verify customer identity via JPN API using 12-digit MyKad.
        Returns citizen data and AML status.
      operationId: verifyMyKad
      parameters:
        - $ref: '#/components/parameters/XIdempotencyKey'
        - $ref: '#/components/parameters/XPosTerminalId'
        - $ref: '#/components/parameters/XGpsLatitude'
        - $ref: '#/components/parameters/XGpsLongitude'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/KycVerifyRequest'
            example:
              mykad_number: "123456789012"
      responses:
        '200':
          description: Verification result
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KycVerifyResponse'
              examples:
                autoApproved:
                  value:
                    status: "AUTO_APPROVED"
                    verification_id: "KYC-uuid-789"
                    full_name: "AHMAD BIN ABU"
                    age: 35
                    timestamp: "2026-03-25T14:45:00+08:00"
                manualReview:
                  value:
                    status: "MANUAL_REVIEW"
                    verification_id: "KYC-uuid-790"
                    reason: "Biometric match failed — queued for manual review"
                    timestamp: "2026-03-25T14:45:00+08:00"
        '400':
          $ref: '#/components/responses/ValidationError'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '422':
          description: Verification failed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              examples:
                mykadNotFound:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_MYKAD_NOT_FOUND"
                      message: "MyKad not found in JPN records"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-300"
                      timestamp: "2026-03-25T14:45:00+08:00"
                invalidFormat:
                  value:
                    status: "FAILED"
                    error:
                      code: "ERR_INVALID_MYKAD_FORMAT"
                      message: "MyKad must be exactly 12 digits"
                      action_code: "DECLINE"
                      trace_id: "trace-abc-301"
                      timestamp: "2026-03-25T14:45:00+08:00"
        '503':
          $ref: '#/components/responses/ServiceUnavailable'

  /api/v1/kyc/biometric:
    post:
      tags: [KYC]
      summary: Biometric match-on-card
      description: |
        Perform biometric (thumbprint) match-on-card verification.
        Must be called after /kyc/verify to link to a verification_id.
        Auto-approves if: match=YES AND AML=CLEAN AND age>=18.
      operationId: biometricMatch
      parameters:
        - $ref: '#/components/parameters/XIdempotencyKey'
        - $ref: '#/components/parameters/XPosTerminalId'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BiometricRequest'
            example:
              verification_id: "KYC-uuid-789"
              biometric_data: "encrypted_thumbprint_blob"
      responses:
        '200':
          description: Biometric match result
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BiometricResponse'
              example:
                status: "AUTO_APPROVED"
                verification_id: "KYC-uuid-789"
                biometric_match: "MATCH"
                timestamp: "2026-03-25T14:46:00+08:00"
        '400':
          $ref: '#/components/responses/ValidationError'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '422':
          description: Biometric failed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'

  # --- Backoffice Endpoints ---
  /api/v1/backoffice/agents:
    get:
      tags: [Backoffice]
      summary: List agents
      operationId: listAgents
      parameters:
        - name: status
          in: query
          schema:
            type: string
            enum: [ACTIVE, SUSPENDED, DEACTIVATED]
        - name: tier
          in: query
          schema:
            type: string
            enum: [BASIC, STANDARD, PREMIUM]
        - name: page
          in: query
          schema:
            type: integer
            default: 0
        - name: size
          in: query
          schema:
            type: integer
            default: 20
      responses:
        '200':
          description: Agent list
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AgentListResponse'
    post:
      tags: [Backoffice]
      summary: Create agent
      operationId: createAgent
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreateAgentRequest'
      responses:
        '201':
          description: Agent created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AgentResponse'
        '422':
          description: Duplicate agent
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'

  /api/v1/backoffice/agents/{agentId}:
    get:
      tags: [Backoffice]
      summary: Get agent details
      operationId: getAgent
      parameters:
        - name: agentId
          in: path
          required: true
          schema:
            type: string
            format: uuid
      responses:
        '200':
          description: Agent details
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AgentResponse'
    put:
      tags: [Backoffice]
      summary: Update agent
      operationId: updateAgent
      parameters:
        - name: agentId
          in: path
          required: true
          schema:
            type: string
            format: uuid
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UpdateAgentRequest'
      responses:
        '200':
          description: Agent updated
        '422':
          description: Cannot deactivate with pending transactions

  /api/v1/backoffice/transactions:
    get:
      tags: [Backoffice]
      summary: List transactions (monitoring)
      operationId: listTransactions
      parameters:
        - name: status
          in: query
          schema:
            type: string
            enum: [PENDING, COMPLETED, FAILED, REVERSED]
        - name: agentId
          in: query
          schema:
            type: string
            format: uuid
        - name: transactionType
          in: query
          schema:
            type: string
        - name: fromDate
          in: query
          schema:
            type: string
            format: date
        - name: toDate
          in: query
          schema:
            type: string
            format: date
        - name: page
          in: query
          schema:
            type: integer
            default: 0
        - name: size
          in: query
          schema:
            type: integer
            default: 50
      responses:
        '200':
          description: Transaction list
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionListResponse'

  /api/v1/backoffice/settlement:
    get:
      tags: [Backoffice]
      summary: Settlement report
      operationId: getSettlement
      parameters:
        - name: date
          in: query
          required: true
          schema:
            type: string
            format: date
        - name: agentId
          in: query
          schema:
            type: string
            format: uuid
      responses:
        '200':
          description: Settlement report
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SettlementResponse'

  /api/v1/backoffice/settlement/export:
    get:
      tags: [Backoffice]
      summary: Export settlement CSV
      operationId: exportSettlement
      parameters:
        - name: date
          in: query
          required: true
          schema:
            type: string
            format: date
      responses:
        '200':
          description: CSV file
          content:
            text/csv:
              schema:
                type: string
                format: binary

  /api/v1/backoffice/kyc/review-queue:
    get:
      tags: [Backoffice]
      summary: Manual KYC review queue
      operationId: getKycReviewQueue
      parameters:
        - name: page
          in: query
          schema:
            type: integer
            default: 0
        - name: size
          in: query
          schema:
            type: integer
            default: 20
      responses:
        '200':
          description: Review queue
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KycReviewQueueResponse'

components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT

  parameters:
    XIdempotencyKey:
      name: X-Idempotency-Key
      in: header
      required: true
      description: UUID v4 for request deduplication
      schema:
        type: string
        format: uuid
    XPosTerminalId:
      name: X-POS-Terminal-Id
      in: header
      required: true
      description: Terminal device identifier
      schema:
        type: string
    XGpsLatitude:
      name: X-GPS-Latitude
      in: header
      required: true
      description: Current terminal GPS latitude
      schema:
        type: number
        format: double
    XGpsLongitude:
      name: X-GPS-Longitude
      in: header
      required: true
      description: Current terminal GPS longitude
      schema:
        type: number
        format: double

  schemas:
    # --- Request Schemas ---
    WithdrawalRequest:
      type: object
      required: [amount, card_data, pin_block, currency]
      properties:
        amount:
          type: number
          format: decimal
          minimum: 0.01
          description: Withdrawal amount in RM
        card_data:
          type: string
          description: Encrypted card data blob from POS
        pin_block:
          type: string
          description: DUKPT-encrypted PIN block
        currency:
          type: string
          enum: [MYR]
          default: MYR

    DepositRequest:
      type: object
      required: [amount, destination_account, currency]
      properties:
        amount:
          type: number
          format: decimal
          minimum: 0.01
          description: Deposit amount in RM
        destination_account:
          type: string
          description: Destination account number (validated via ProxyEnquiry)
        currency:
          type: string
          enum: [MYR]
          default: MYR

    BalanceInquiryRequest:
      type: object
      required: [card_data, pin_block]
      properties:
        card_data:
          type: string
        pin_block:
          type: string

    KycVerifyRequest:
      type: object
      required: [mykad_number]
      properties:
        mykad_number:
          type: string
          pattern: '^\d{12}$'
          description: 12-digit MyKad number

    BiometricRequest:
      type: object
      required: [verification_id, biometric_data]
      properties:
        verification_id:
          type: string
          format: uuid
        biometric_data:
          type: string
          description: Encrypted thumbprint blob

    CreateAgentRequest:
      type: object
      required: [businessName, tier, mykadNumber, phoneNumber, merchantGpsLat, merchantGpsLng]
      properties:
        businessName:
          type: string
          maxLength: 200
        tier:
          type: string
          enum: [BASIC, STANDARD, PREMIUM]
        mykadNumber:
          type: string
          pattern: '^\d{12}$'
        phoneNumber:
          type: string
        merchantGpsLat:
          type: number
          format: double
        merchantGpsLng:
          type: number
          format: double

    UpdateAgentRequest:
      type: object
      properties:
        businessName:
          type: string
        tier:
          type: string
          enum: [MICRO, STANDARD, PREMIER]
        status:
          type: string
          enum: [ACTIVE, SUSPENDED, DEACTIVATED]
        phoneNumber:
          type: string
        merchantGpsLat:
          type: number
          format: double
        merchantGpsLng:
          type: number
          format: double

    # --- Response Schemas ---
    TransactionSuccessResponse:
      type: object
      properties:
        status:
          type: string
          enum: [COMPLETED]
        transaction_id:
          type: string
          format: uuid
        amount:
          type: number
          format: decimal
        customer_fee:
          type: number
          format: decimal
        reference_number:
          type: string
        timestamp:
          type: string
          format: date-time

    ErrorResponse:
      type: object
      properties:
        status:
          type: string
          enum: [FAILED]
        error:
          type: object
          properties:
            code:
              type: string
              description: Error code from registry (ERR_xxx)
            message:
              type: string
              description: Human-readable error message
            action_code:
              type: string
              enum: [DECLINE, RETRY, REVIEW]
              description: Suggested action for the caller
            trace_id:
              type: string
              description: Distributed trace ID for debugging
            timestamp:
              type: string
              format: date-time

    BalanceInquiryResponse:
      type: object
      properties:
        status:
          type: string
          enum: [COMPLETED]
        balance:
          type: number
          format: decimal
        currency:
          type: string
        account_masked:
          type: string
          description: Masked account number (e.g., ****7890)
        timestamp:
          type: string
          format: date-time

    AgentBalanceResponse:
      type: object
      properties:
        status:
          type: string
          enum: [COMPLETED]
        balance:
          type: number
          format: decimal
        reserved_balance:
          type: number
          format: decimal
        available_balance:
          type: number
          format: decimal
        currency:
          type: string
        timestamp:
          type: string
          format: date-time

    KycVerifyResponse:
      type: object
      properties:
        status:
          type: string
          enum: [AUTO_APPROVED, MANUAL_REVIEW, REJECTED]
        verification_id:
          type: string
          format: uuid
        full_name:
          type: string
        age:
          type: integer
        reason:
          type: string
        timestamp:
          type: string
          format: date-time

    BiometricResponse:
      type: object
      properties:
        status:
          type: string
          enum: [AUTO_APPROVED, MANUAL_REVIEW, REJECTED]
        verification_id:
          type: string
          format: uuid
        biometric_match:
          type: string
          enum: [MATCH, NO_MATCH]
        timestamp:
          type: string
          format: date-time

    AgentResponse:
      type: object
      properties:
        agentId:
          type: string
          format: uuid
        agentCode:
          type: string
        businessName:
          type: string
        tier:
          type: string
          enum: [MICRO, STANDARD, PREMIER]
        status:
          type: string
          enum: [ACTIVE, SUSPENDED, DEACTIVATED]
        phoneNumber:
          type: string
        merchantGpsLat:
          type: number
          format: double
        merchantGpsLng:
          type: number
          format: double
        createdAt:
          type: string
          format: date-time

    AgentListResponse:
      type: object
      properties:
        content:
          type: array
          items:
            $ref: '#/components/schemas/AgentResponse'
        totalElements:
          type: integer
        totalPages:
          type: integer
        page:
          type: integer

    TransactionListResponse:
      type: object
      properties:
        content:
          type: array
          items:
            $ref: '#/components/schemas/TransactionSummary'
        totalElements:
          type: integer
        totalPages:
          type: integer
        page:
          type: integer

    TransactionSummary:
      type: object
      properties:
        transactionId:
          type: string
          format: uuid
        transactionType:
          type: string
        amount:
          type: number
          format: decimal
        status:
          type: string
          enum: [PENDING, COMPLETED, FAILED, REVERSED]
        agentCode:
          type: string
        customerCardMasked:
          type: string
        createdAt:
          type: string
          format: date-time

    SettlementResponse:
      type: object
      properties:
        date:
          type: string
          format: date
        totalDeposits:
          type: number
          format: decimal
        totalWithdrawals:
          type: number
          format: decimal
        totalCommissions:
          type: number
          format: decimal
        netSettlement:
          type: number
          format: decimal
        agentBreakdown:
          type: array
          items:
            type: object
            properties:
              agentCode:
                type: string
              agentTier:
                type: string
              deposits:
                type: number
              withdrawals:
                type: number
              commissions:
                type: number
              netAmount:
                type: number

    KycReviewQueueResponse:
      type: object
      properties:
        content:
          type: array
          items:
            type: object
            properties:
              verificationId:
                type: string
                format: uuid
              mykadMasked:
                type: string
              fullName:
                type: string
              amlStatus:
                type: string
              biometricMatch:
                type: string
              rejectionReason:
                type: string
              createdAt:
                type: string
                format: date-time
        totalElements:
          type: integer
        totalPages:
          type: integer

  responses:
    ValidationError:
      description: Request validation failed
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
          example:
            status: "FAILED"
            error:
              code: "ERR_VAL_INVALID_AMOUNT"
